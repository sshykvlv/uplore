# ─── Database ────────────────────────────────────────────────────────────────
# Path to the SQLite database file. Directory is created automatically.
DATABASE_PATH=./data/uplore.db

# ─── Session ─────────────────────────────────────────────────────────────────
# Random secret used to sign session cookies (HMAC-SHA256).
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-me-with-a-random-secret

# ─── Telegram auth ───────────────────────────────────────────────────────────
# Bot token from @BotFather. Required for production Telegram login.
# Set the domain in BotFather with: /setdomain -> uplore.ykv.lv
TELEGRAM_BOT_TOKEN=

# ─── Dev login ───────────────────────────────────────────────────────────────
# Set to 'true' to enable /api/auth/dev (fake username login).
# NEVER enable in production (also blocked when NODE_ENV=production).
ALLOW_DEV_LOGIN=true

# ─── Site ────────────────────────────────────────────────────────────────────
# Public URL of the deployment (used for redirects and OG tags).
PUBLIC_URL=http://localhost:3000

# ─── Analytics (optional) ────────────────────────────────────────────────────
# Umami self-hosted analytics. Leave blank to disable.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=
