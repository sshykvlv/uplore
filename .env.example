# ─── Database ────────────────────────────────────────────────────────────────
# Path to the SQLite database file. Directory is created automatically.
# In Docker the default is /data/uplore.db (set in the image).
DATABASE_PATH=./data/uplore.db

# ─── Uploads ─────────────────────────────────────────────────────────────────
# Directory where uploaded images are stored.
# In Docker the default is /data/uploads (set in the image).
UPLOADS_PATH=./uploads

# ─── Session ─────────────────────────────────────────────────────────────────
# Random secret used to sign session cookies (HMAC-SHA256).
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-me-with-a-random-secret

# ─── Telegram auth ───────────────────────────────────────────────────────────
# Bot token from @BotFather. Required for production Telegram login.
# Set the domain in BotFather with: /setdomain -> your-domain.example.com
TELEGRAM_BOT_TOKEN=

# ─── Dev login ───────────────────────────────────────────────────────────────
# Set to 'true' to enable /api/auth/dev (fake username login).
# NEVER enable in production (also blocked when NODE_ENV=production).
ALLOW_DEV_LOGIN=true

# ─── Site ────────────────────────────────────────────────────────────────────
# Public URL of the deployment (used for redirects and OG tags).
PUBLIC_URL=http://localhost:3000

# ─── Analytics (optional) ────────────────────────────────────────────────────
# Umami self-hosted analytics. Leave blank to disable entirely.
# NEXT_PUBLIC_* vars are embedded at build time — rebuild after changing these.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=
