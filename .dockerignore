# Dependencies — installed fresh inside the image
node_modules

# Next.js build output — rebuilt inside the image
.next

# Git history — not needed in image
.git
.gitignore

# Local data volumes — mounted at runtime
data
uploads

# Dev environment files
.env
.env.*
!.env.example

# Docs and design files — not needed at runtime
docs
design-mocks

# Editor and OS cruft
.DS_Store
*.log
.vscode
.idea

# Test output
coverage
